<decoder name="idrac_rfc5424_line">
  <prematch>Severity:\s</prematch>
  <regex>^(?:&lt;\d+&gt;)?(\d{4}-\d{2}-\d{2}T\S+)\s+(\S+)\s+Severity:\s*([^,]+),\s*Category:\s*([^,]+),\s*MessageID:\s*([^,]+),\s*Message:\s*(.*)$</regex>
  <order>timestamp,hostname,severity,category,message_id,message</order>
</decoder>
